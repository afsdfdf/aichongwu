{%- comment -%}
Memory Mint Compatible Widget
最小改动接入：
1. 放到 product template / Custom Liquid
2. 建议放在变体选择器上方
3. 保持店铺原有结构不变
{%- endcomment -%}

<div
  id="ai-preview-root"
  data-api-base="https://aichongwu.vercel.app"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-type="{{ product.type | default: product.handle | escape }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
></div>
<script src="https://aichongwu.vercel.app/widget.js" defer></script>
